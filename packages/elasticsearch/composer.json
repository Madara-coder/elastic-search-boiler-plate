{
    "name": "app/elasticsearch",
    "description": "Reusable Elasticsearch integration for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "elasticsearch/elasticsearch": "^8.0",
        "laravel/framework": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Packages\\Elasticsearch\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "App\\Packages\\Elasticsearch\\ElasticsearchServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
